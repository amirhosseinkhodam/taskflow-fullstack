{
  "extends": "./tsconfig.json",
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "paths": {
      "@models/*": ["frontend/src/app/models/*"]
    }
  }
}
